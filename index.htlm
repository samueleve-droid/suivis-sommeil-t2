<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Suivi Santé">
<meta name="theme-color" content="#0d0d12">
<title>Suivi Santé</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">

<!-- PWA Manifest inline -->
<script>
const manifestData = {
  name: "Suivi Santé",
  short_name: "Suivi Santé",
  description: "Suivi médicaments, sommeil et énergie",
  start_url: ".",
  display: "standalone",
  background_color: "#0d0d12",
  theme_color: "#0d0d12",
  icons: [
    { src: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'%3E%3Crect width='192' height='192' rx='40' fill='%230d0d12'/%3E%3Ctext x='96' y='130' font-size='100' text-anchor='middle'%3E💊%3C/text%3E%3C/svg%3E", sizes: "192x192", type: "image/svg+xml" }
  ]
};
const blob = new Blob([JSON.stringify(manifestData)], {type: 'application/json'});
const manifestURL = URL.createObjectURL(blob);
document.write('<link rel="manifest" href="' + manifestURL + '">');
</script>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d0d12;--surface:#15151e;--surface2:#1c1c28;--border:#252535;
  --text:#ebebf5;--muted:#6060a0;--sunosi:#e8c96a;--mela:#9d7cf0;
  --wake:#5ee8b0;--sleep:#7b8cf8;--nap:#fc9a4a;--green:#34d399;--red:#f87171;--r:13px;
  --safe-top: env(safe-area-inset-top, 0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
html{height:100%;-webkit-text-size-adjust:100%}
body{
  background:var(--bg);color:var(--text);
  font-family:'DM Sans',sans-serif;
  height:100%;overflow-x:hidden;
  -webkit-tap-highlight-color:transparent;
}
#root{min-height:100vh}
.app{min-height:100vh;max-width:480px;margin:0 auto;padding-bottom:calc(80px + var(--safe-bottom))}
.header{padding:calc(22px + var(--safe-top)) 20px 10px}
.header-top{display:flex;align-items:baseline;gap:10px;margin-bottom:3px}
.app-title{font-family:'DM Serif Display',serif;font-size:24px}
.header-clock{font-family:'DM Serif Display',serif;font-size:22px;font-style:italic;color:var(--muted)}
.header-sub{font-size:13px;color:var(--muted)}
.past-badge{color:var(--nap);font-size:12px}
.nav{display:flex;gap:6px;padding:10px 20px;border-bottom:1px solid var(--border);overflow-x:auto}
.nav::-webkit-scrollbar{display:none}
.nav-btn{padding:6px 14px;border-radius:100px;border:1px solid var(--border);background:transparent;color:var(--muted);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;white-space:nowrap;transition:all .12s;-webkit-appearance:none}
.nav-btn.active{background:var(--surface2);color:var(--text);border-color:#38384e}
.date-picker{display:flex;gap:6px;padding:12px 20px;overflow-x:auto;border-bottom:1px solid var(--border)}
.date-picker::-webkit-scrollbar{display:none}
.date-chip{display:flex;flex-direction:column;align-items:center;padding:7px 10px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;min-width:46px;transition:all .12s;font-family:'DM Sans',sans-serif;-webkit-appearance:none}
.date-chip.today{border-color:rgba(94,232,176,0.3);color:var(--wake)}
.date-chip.selected{background:var(--surface2);color:var(--text);border-color:#38384e}
.chip-day{font-size:10px;text-transform:capitalize}
.chip-num{font-size:16px;font-weight:600;margin-top:2px}
.content{padding:14px 20px;display:flex;flex-direction:column;gap:14px}
.section{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.sec-title{padding:11px 16px 7px;font-size:10px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)}
.sec-body{padding:12px 16px;display:flex;flex-direction:column;gap:8px}
.med-row{display:flex;align-items:center;justify-content:space-between;padding:11px 13px;border-radius:10px;border:1px solid transparent;transition:all .12s}
.row-sunosi{background:rgba(232,201,106,0.06);border-color:rgba(232,201,106,0.15)}
.row-mela{background:rgba(157,124,240,0.06);border-color:rgba(157,124,240,0.15)}
.taken{opacity:.65}
.med-left{flex:1}
.med-name{font-weight:600;font-size:14px}
.med-win{font-size:11px;color:var(--muted);margin-top:2px}
.med-dose{font-size:10px;font-weight:700;padding:1px 6px;border-radius:100px;margin-left:4px}
.ds{background:rgba(232,201,106,0.15);color:var(--sunosi)}
.dm{background:rgba(157,124,240,0.15);color:var(--mela)}
.med-ok{font-size:13px;font-weight:600;color:var(--green);margin-right:6px}
.event-row{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border)}
.event-row:last-of-type{border-bottom:none}
.event-left{display:flex;align-items:center;gap:11px}
.ev-icon{font-size:19px;width:26px;text-align:center;flex-shrink:0}
.ev-label{font-size:14px;font-weight:500}
.ev-time{font-size:13px;color:var(--muted);font-weight:600;margin-top:1px}
.ev-actions{display:flex;align-items:center;gap:6px}
.a-btn{border:none;border-radius:7px;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:500;transition:all .12s;-webkit-appearance:none}
.a-btn.log{background:rgba(94,232,176,0.1);color:var(--wake);font-size:12px;padding:5px 10px;border:1px solid rgba(94,232,176,0.2)}
.a-btn.edit{background:var(--surface2);color:var(--muted);font-size:14px;padding:5px 9px;border:1px solid var(--border)}
.comment-wrap{margin-top:4px}
.comment-header{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px}
.comment-area{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:13px;padding:10px 12px;resize:none;outline:none;line-height:1.5;transition:border-color .12s;-webkit-appearance:none}
.comment-area:focus{border-color:#3a3a5a}
.comment-area::placeholder{color:var(--muted)}
.nap-item{display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:rgba(252,154,74,0.06);border:1px solid rgba(252,154,74,0.15);border-radius:9px;font-size:13px}
.nap-times{color:var(--text)}
.nap-dur{color:var(--nap);font-weight:600}
.nap-btns{display:flex;gap:8px;flex-wrap:wrap}
.nap-btn{flex:1;padding:11px 14px;border-radius:9px;border:1px dashed rgba(252,154,74,0.35);background:rgba(252,154,74,0.06);color:var(--nap);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;-webkit-appearance:none}
.nap-btn.outline{background:transparent;border-style:dashed;color:var(--muted);border-color:var(--border)}
.nap-btn.active{border-style:solid;border-color:var(--nap);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
.sum-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.sum-card{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:12px 14px}
.sum-l{font-size:11px;color:var(--muted);margin-bottom:3px}
.sum-v{font-family:'DM Serif Display',serif;font-size:22px}
.sum-v.wake{color:var(--wake)}.sum-v.sleep{color:var(--sleep)}.sum-v.nap{color:var(--nap)}
.prog-wrap{background:var(--border);border-radius:100px;height:3px;margin-top:10px;overflow:hidden}
.prog-fill{height:100%;border-radius:100px;background:linear-gradient(90deg,var(--sleep),var(--wake));transition:width .5s}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.75);display:flex;align-items:flex-end;justify-content:center;z-index:100;padding:20px;padding-bottom:calc(20px + var(--safe-bottom));backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:24px 20px;width:100%;max-width:440px}
.modal-title{font-family:'DM Serif Display',serif;font-size:20px;margin-bottom:18px}
.modal-row{margin-bottom:0}
.modal-label{font-size:12px;color:var(--muted);display:block;margin-bottom:6px}
.time-input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:9px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:24px;padding:13px 16px;outline:none;-webkit-appearance:none}
.time-input:focus{border-color:#3a3a5a}
.modal-actions{display:flex;gap:8px;margin-top:20px}
.modal-btn{flex:1;padding:12px;border-radius:9px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;border:1px solid transparent;transition:all .12s;-webkit-appearance:none}
.modal-btn.save{background:var(--wake);color:#0d0d12}
.modal-btn.save:disabled{opacity:.3;cursor:default}
.modal-btn.cancel{background:var(--surface2);color:var(--muted);border-color:var(--border)}
.modal-btn.delete{background:rgba(248,113,113,0.1);color:var(--red);border-color:rgba(248,113,113,0.2);flex:0.6}
.list{display:flex;flex-direction:column;gap:10px}
.hcard{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px 16px;display:flex;flex-direction:column;gap:8px;cursor:pointer;transition:border-color .12s}
.hcard-top{display:flex;justify-content:space-between;align-items:flex-start}
.hcard-date{font-weight:600;font-size:14px}
.hcard-sub{font-size:12px;color:var(--muted);margin-top:2px}
.hcard-total{font-family:'DM Serif Display',serif;font-size:22px;color:var(--wake)}
.badge-row{display:flex;gap:5px;flex-wrap:wrap}
.mbadge{font-size:11px;padding:3px 8px;border-radius:100px;font-weight:500}
.mbadge.ok{background:rgba(52,211,153,0.1);color:var(--green);border:1px solid rgba(52,211,153,0.2)}
.mbadge.miss{background:rgba(248,113,113,0.07);color:var(--red);border:1px solid rgba(248,113,113,0.12)}
.hcard-nap{font-size:12px;color:var(--nap)}
.hcard-comments{background:var(--surface2);border-radius:8px;padding:8px 10px;display:flex;flex-direction:column;gap:4px}
.hcc{font-size:12px;color:var(--muted)}
.hcard-hint{font-size:11px;color:#3a3a55;text-align:right}
.scard{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px 16px;display:flex;justify-content:space-between;align-items:center}
.sc-period{font-size:14px;font-weight:600}
.sc-sub{font-size:11px;color:var(--muted);margin-top:2px}
.sc-vals{display:flex;gap:14px}
.scv{text-align:right}
.scv-l{font-size:10px;color:var(--muted)}
.scv-n{font-size:15px;font-weight:700}
.scv.night .scv-n{color:var(--sleep)}.scv.nap .scv-n{color:var(--nap)}.scv.total .scv-n{color:var(--wake)}
.empty{text-align:center;padding:40px 16px;color:var(--muted);font-size:14px}
.install-banner{display:none;align-items:center;gap:10px;padding:10px 20px;background:rgba(94,232,176,0.08);border-bottom:1px solid rgba(94,232,176,0.15);font-size:12px;color:var(--muted)}
.install-banner.show{display:flex}
.install-icon{font-size:20px}
</style>
</head>
<body>
<div id="root"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>

<script type="text/babel">
const { useState, useEffect, useRef } = React;

const STORAGE_KEY = "med-sleep-tracker-v2";
const pad = n => String(n).padStart(2,"0");
const formatTime = iso => { if(!iso) return null; const d=new Date(iso); return `${pad(d.getHours())}:${pad(d.getMinutes())}`; };
const todayKey = () => new Date().toISOString().slice(0,10);
const minutesBetween = (a,b) => { if(!a||!b) return 0; const diff=Math.round((new Date(b)-new Date(a))/60000); return diff<0?diff+1440:diff; };
const formatDuration = mins => { if(!mins||mins<=0) return "—"; const h=Math.floor(Math.abs(mins)/60),m=Math.abs(mins)%60; return h>0?`${h}h${m>0?pad(m):""}`:`${m}m`; };
const getWeekKey = dateStr => { const d=new Date(dateStr+"T12:00:00"),day=d.getDay(),diff=d.getDate()-day+(day===0?-6:1),mon=new Date(d); mon.setDate(diff); return mon.toISOString().slice(0,10); };
const getMonthKey = dateStr => dateStr.slice(0,7);
const emptyDay = () => ({wakeUp:null,bedtime:null,fallAsleep:null,naps:[],meds:{sunosi_morning:null,sunosi_noon:null,melatonin:null},sleepComment:"",dayComment:""});
const buildISO = (dateKey,hhmm) => { const [hh,mm]=hhmm.split(":").map(Number),d=new Date(dateKey+"T00:00:00"); d.setHours(hh,mm,0,0); return d.toISOString(); };
const LAST_14 = () => { const days=[]; for(let i=0;i<14;i++){const d=new Date();d.setDate(d.getDate()-i);days.push(d.toISOString().slice(0,10));} return days; };

function TimeModal({label,currentISO,dateKey,onSave,onDelete,onClose}){
  const [val,setVal]=useState(currentISO?formatTime(currentISO):"");
  return (
    <div className="modal-overlay" onClick={onClose}>
      <div className="modal" onClick={e=>e.stopPropagation()}>
        <div className="modal-title">{label}</div>
        <input className="time-input" type="time" value={val} onChange={e=>setVal(e.target.value)} autoFocus/>
        <div className="modal-actions">
          {currentISO&&<button className="modal-btn delete" onClick={()=>{onDelete();onClose();}}>Supprimer</button>}
          <button className="modal-btn cancel" onClick={onClose}>Annuler</button>
          <button className="modal-btn save" disabled={!val} onClick={()=>{if(val){onSave(buildISO(dateKey,val));onClose();}}}>Enregistrer</button>
        </div>
      </div>
    </div>
  );
}

function NapModal({nap,napIdx,dateKey,onSave,onDelete,onClose}){
  const [start,setStart]=useState(nap?.start?formatTime(nap.start):"");
  const [end,setEnd]=useState(nap?.end?formatTime(nap.end):"");
  return (
    <div className="modal-overlay" onClick={onClose}>
      <div className="modal" onClick={e=>e.stopPropagation()}>
        <div className="modal-title">{napIdx!==null?"Modifier la sieste":"Ajouter une sieste"}</div>
        <div className="modal-row">
          <label className="modal-label">Début</label>
          <input className="time-input" type="time" value={start} onChange={e=>setStart(e.target.value)} autoFocus/>
        </div>
        <div className="modal-row" style={{marginTop:14}}>
          <label className="modal-label">Fin</label>
          <input className="time-input" type="time" value={end} onChange={e=>setEnd(e.target.value)}/>
        </div>
        <div className="modal-actions">
          {napIdx!==null&&<button className="modal-btn delete" onClick={()=>{onDelete(napIdx);onClose();}}>Supprimer</button>}
          <button className="modal-btn cancel" onClick={onClose}>Annuler</button>
          <button className="modal-btn save" disabled={!start} onClick={()=>{if(start){onSave(napIdx,{start:buildISO(dateKey,start),end:end?buildISO(dateKey,end):null});onClose();}}}>Enregistrer</button>
        </div>
      </div>
    </div>
  );
}

function DatePicker({selectedDate,onChange}){
  const days=LAST_14();
  return (
    <div className="date-picker">
      {days.map(d=>{
        const dt=new Date(d+"T12:00:00"),isToday=d===todayKey(),isSel=d===selectedDate;
        return (
          <button key={d} className={`date-chip${isSel?" selected":""}${isToday?" today":""}`} onClick={()=>onChange(d)}>
            <span className="chip-day">{dt.toLocaleDateString("fr-FR",{weekday:"short"})}</span>
            <span className="chip-num">{dt.getDate()}</span>
          </button>
        );
      })}
    </div>
  );
}

function CommentBox({label,icon,value,onChange}){
  return (
    <div className="comment-wrap">
      <div className="comment-header">{icon} {label}</div>
      <textarea className="comment-area" value={value||""} onChange={e=>onChange(e.target.value)} placeholder="Ajouter une note…" rows={3}/>
    </div>
  );
}

function App(){
  const [data,setData]=useState({});
  const [view,setView]=useState("today");
  const [activeDate,setActiveDate]=useState(todayKey());
  const [now,setNow]=useState(new Date());
  const [modal,setModal]=useState(null);
  const [showBanner,setShowBanner]=useState(false);

  useEffect(()=>{
    try{const s=JSON.parse(localStorage.getItem(STORAGE_KEY)||"{}");setData(s);}catch{}
    // Show install banner on Safari iOS if not already installed
    const isIOS=/iphone|ipad|ipod/i.test(navigator.userAgent);
    const isStandalone=window.navigator.standalone;
    if(isIOS&&!isStandalone) setShowBanner(true);
  },[]);
  useEffect(()=>{const t=setInterval(()=>setNow(new Date()),30000);return()=>clearInterval(t);},[]);

  const save=nd=>{setData(nd);localStorage.setItem(STORAGE_KEY,JSON.stringify(nd));};
  const getDay=(key=activeDate)=>({...emptyDay(),...(data[key]||{})});
  const updateDay=(key,fn)=>{save({...data,[key]:fn(getDay(key))});};
  const setField=(field,iso)=>updateDay(activeDate,d=>({...d,[field]:iso}));
  const clearField=field=>updateDay(activeDate,d=>({...d,[field]:null}));
  const setMed=(med,iso)=>updateDay(activeDate,d=>({...d,meds:{...d.meds,[med]:iso}}));
  const clearMed=med=>updateDay(activeDate,d=>({...d,meds:{...d.meds,[med]:null}}));
  const saveNap=(idx,nap)=>updateDay(activeDate,d=>{const naps=[...(d.naps||[])];if(idx===null)naps.push(nap);else naps[idx]=nap;return{...d,naps};});
  const deleteNap=idx=>updateDay(activeDate,d=>({...d,naps:d.naps.filter((_,i)=>i!==idx)}));
  const quickLog=field=>setField(field,new Date().toISOString());
  const quickMed=med=>setMed(med,new Date().toISOString());

  const day=getDay(activeDate);
  const isToday=activeDate===todayKey();
  const hasActiveNap=day.naps?.some(n=>!n.end);
  const totalNapMins=d=>(d.naps||[]).reduce((acc,n)=>acc+(n.end?minutesBetween(n.start,n.end):0),0);
  const nightMins=d=>d.wakeUp&&d.fallAsleep?minutesBetween(d.fallAsleep,d.wakeUp):0;
  const allDays=Object.entries(data).sort(([a],[b])=>a.localeCompare(b));

  const weekStats=()=>{const w={};allDays.forEach(([date,d])=>{const k=getWeekKey(date);if(!w[k])w[k]={nights:[],naps:[],dates:[]};w[k].dates.push(date);const nm=nightMins(d);if(nm>0)w[k].nights.push(nm);const np=totalNapMins(d);if(np>0)w[k].naps.push(np);});return w;};
  const monthStats=()=>{const m={};allDays.forEach(([date,d])=>{const k=getMonthKey(date);if(!m[k])m[k]={nights:[],naps:[],dates:[]};m[k].dates.push(date);const nm=nightMins(d);if(nm>0)m[k].nights.push(nm);const np=totalNapMins(d);if(np>0)m[k].naps.push(np);});return m;};
  const avg=arr=>arr.length?Math.round(arr.reduce((a,b)=>a+b,0)/arr.length):0;

  return (
    <div className="app">
      {modal?.type==="time"&&<TimeModal label={modal.label} currentISO={modal.val} dateKey={activeDate} onSave={iso=>modal.isMed?setMed(modal.field,iso):setField(modal.field,iso)} onDelete={()=>modal.isMed?clearMed(modal.field):clearField(modal.field)} onClose={()=>setModal(null)}/>}
      {modal?.type==="nap"&&<NapModal nap={modal.nap} napIdx={modal.idx} dateKey={activeDate} onSave={saveNap} onDelete={deleteNap} onClose={()=>setModal(null)}/>}

      {showBanner&&(
        <div className="install-banner show">
          <span className="install-icon">📲</span>
          <span>Pour l'utiliser comme une app : Safari → <strong>Partager</strong> → <strong>Sur l'écran d'accueil</strong></span>
        </div>
      )}

      <div className="header">
        <div className="header-top">
          <span className="app-title">Suivi Santé</span>
          {isToday&&<span className="header-clock">{pad(now.getHours())}:{pad(now.getMinutes())}</span>}
        </div>
        <div className="header-sub">
          {new Date(activeDate+"T12:00:00").toLocaleDateString("fr-FR",{weekday:"long",day:"numeric",month:"long"})}
          {!isToday&&<span className="past-badge"> · jour passé</span>}
        </div>
      </div>

      <div className="nav">
        {["today","history","week","month"].map(v=>(
          <button key={v} className={`nav-btn${view===v?" active":""}`} onClick={()=>setView(v)}>
            {{today:"Journal",history:"Historique",week:"Semaine",month:"Mois"}[v]}
          </button>
        ))}
      </div>

      {view==="today"&&<DatePicker selectedDate={activeDate} onChange={setActiveDate}/>}

      <div className="content">
        {view==="today"&&<JournalView day={day} activeDate={activeDate} isToday={isToday} quickLog={quickLog} quickMed={quickMed} setModal={setModal} saveNap={saveNap} hasActiveNap={hasActiveNap} totalNapMins={totalNapMins} nightMins={nightMins} updateDay={updateDay}/>}
        {view==="history"&&<HistoryView allDays={allDays} totalNapMins={totalNapMins} nightMins={nightMins} onSelectDate={d=>{setActiveDate(d);setView("today");}}/>}
        {view==="week"&&<WeekView weekStats={weekStats()} avg={avg}/>}
        {view==="month"&&<MonthView monthStats={monthStats()} avg={avg}/>}
      </div>
    </div>
  );
}

function JournalView({day,activeDate,isToday,quickLog,quickMed,setModal,saveNap,hasActiveNap,totalNapMins,nightMins,updateDay}){
  const nm=nightMins(day),np=totalNapMins(day),total=nm+np,pct=Math.min(100,Math.round((total/480)*100));

  const EventRow=({field,label,icon,color,value})=>(
    <div className="event-row">
      <div className="event-left">
        <span className="ev-icon">{icon}</span>
        <div><div className="ev-label">{label}</div><div className="ev-time" style={{color:value?color:undefined}}>{value?formatTime(value):"—"}</div></div>
      </div>
      <div className="ev-actions">
        {!value&&isToday&&<button className="a-btn log" onClick={()=>quickLog(field)}>Maintenant</button>}
        <button className="a-btn edit" onClick={()=>setModal({type:"time",label,field,val:value,isMed:false})}>✎</button>
      </div>
    </div>
  );

  const MedRow=({id,label,dose,doseClass,window:win,value})=>(
    <div className={`med-row ${id==="melatonin"?"row-mela":"row-sunosi"}${value?" taken":""}`}>
      <div className="med-left">
        <div className="med-name">{label} <span className={`med-dose ${doseClass}`}>{dose}</span></div>
        <div className="med-win">{win}</div>
      </div>
      <div className="ev-actions">
        {!value&&isToday&&<button className="a-btn log" onClick={()=>quickMed(id)}>Maintenant</button>}
        {value&&<span className="med-ok">✓ {formatTime(value)}</span>}
        <button className="a-btn edit" onClick={()=>setModal({type:"time",label,field:id,val:value,isMed:true})}>✎</button>
      </div>
    </div>
  );

  return (
    <>
      <div className="section">
        <div className="sec-title">💊 Médicaments</div>
        <div className="sec-body">
          <MedRow id="sunosi_morning" label="Sunosi" dose="×2" doseClass="ds" window="Réveil · 8h – 10h" value={day.meds.sunosi_morning}/>
          <MedRow id="sunosi_noon" label="Sunosi" dose="×1" doseClass="ds" window="Midi · 12h00" value={day.meds.sunosi_noon}/>
          <MedRow id="melatonin" label="Mélatonine" dose="×1" doseClass="dm" window="Soir · 22h – 22h30" value={day.meds.melatonin}/>
        </div>
      </div>
      <div className="section">
        <div className="sec-title">🌙 Sommeil & Réveil</div>
        <div className="sec-body">
          <EventRow field="wakeUp" label="Réveil" icon="☀️" color="var(--wake)" value={day.wakeUp}/>
          <EventRow field="bedtime" label="Coucher (au lit)" icon="🛏️" color="var(--sleep)" value={day.bedtime}/>
          <EventRow field="fallAsleep" label="Endormissement" icon="😴" color="var(--mela)" value={day.fallAsleep}/>
          <CommentBox label="Qualité du sommeil" icon="💬" value={day.sleepComment} onChange={v=>updateDay(activeDate,d=>({...d,sleepComment:v}))}/>
        </div>
      </div>
      <div className="section">
        <div className="sec-title">🛌 Sieste</div>
        <div className="sec-body">
          {(day.naps||[]).map((nap,i)=>(
            <div key={i} className="nap-item">
              <span className="nap-times">
                {formatTime(nap.start)} → {nap.end?formatTime(nap.end):<em>en cours…</em>}
                {nap.end&&<span className="nap-dur"> · {formatDuration(minutesBetween(nap.start,nap.end))}</span>}
              </span>
              <button className="a-btn edit" onClick={()=>setModal({type:"nap",nap,idx:i})}>✎</button>
            </div>
          ))}
          <div className="nap-btns">
            {isToday&&(hasActiveNap
              ?<button className="nap-btn active" onClick={()=>updateDay(activeDate,d=>({...d,naps:d.naps.map((n,i)=>i===d.naps.length-1&&!n.end?{...n,end:new Date().toISOString()}:n)}))}>⏹ Fin de sieste</button>
              :<button className="nap-btn" onClick={()=>saveNap(null,{start:new Date().toISOString(),end:null})}>+ Sieste maintenant</button>
            )}
            <button className="nap-btn outline" onClick={()=>setModal({type:"nap",nap:null,idx:null})}>+ Saisir manuellement</button>
          </div>
        </div>
      </div>
      <div className="section">
        <div className="sec-title">📊 Résumé du jour</div>
        <div className="sec-body">
          <div className="sum-grid">
            <div className="sum-card"><div className="sum-l">Réveil</div><div className="sum-v wake">{day.wakeUp?formatTime(day.wakeUp):"—"}</div></div>
            <div className="sum-card"><div className="sum-l">Endormissement</div><div className="sum-v sleep">{day.fallAsleep?formatTime(day.fallAsleep):"—"}</div></div>
            <div className="sum-card"><div className="sum-l">Nuit</div><div className="sum-v sleep">{formatDuration(nm)}</div></div>
            <div className="sum-card"><div className="sum-l">Sieste(s)</div><div className="sum-v nap">{formatDuration(np)}</div></div>
          </div>
          <div className="sum-card" style={{marginTop:0}}>
            <div className="sum-l">Total sommeil / 24h</div>
            <div className="sum-v wake">{formatDuration(total)}</div>
            <div className="prog-wrap"><div className="prog-fill" style={{width:`${pct}%`}}/></div>
          </div>
          <CommentBox label="Énergie & journée" icon="⚡" value={day.dayComment} onChange={v=>updateDay(activeDate,d=>({...d,dayComment:v}))}/>
        </div>
      </div>
    </>
  );
}

function HistoryView({allDays,totalNapMins,nightMins,onSelectDate}){
  if(!allDays.length) return <div className="empty">Aucune donnée enregistrée.</div>;
  return (
    <div className="list">
      {[...allDays].reverse().map(([date,day])=>{
        const nm=nightMins(day),np=totalNapMins(day),total=nm+np;
        const d=new Date(date+"T12:00:00");
        return (
          <div key={date} className="hcard" onClick={()=>onSelectDate(date)}>
            <div className="hcard-top">
              <div>
                <div className="hcard-date">{d.toLocaleDateString("fr-FR",{weekday:"short",day:"numeric",month:"short"})}</div>
                <div className="hcard-sub">{day.wakeUp?`Réveil ${formatTime(day.wakeUp)}`:"Réveil —"}{day.fallAsleep?` · Dodo ${formatTime(day.fallAsleep)}`:""}</div>
              </div>
              <div className="hcard-total">{formatDuration(total)}</div>
            </div>
            <div className="badge-row">
              {["sunosi_morning","sunosi_noon","melatonin"].map(med=>(
                <span key={med} className={`mbadge ${day.meds?.[med]?"ok":"miss"}`}>
                  {{sunosi_morning:"Sunosi mat.",sunosi_noon:"Sunosi midi",melatonin:"Méla."}[med]}{day.meds?.[med]?` ${formatTime(day.meds[med])}`:" ✗"}
                </span>
              ))}
            </div>
            {(day.naps||[]).filter(n=>n.end).length>0&&<div className="hcard-nap">🛌 {day.naps.filter(n=>n.end).map(n=>`${formatTime(n.start)}–${formatTime(n.end)} (${formatDuration(minutesBetween(n.start,n.end))})`).join(" · ")}</div>}
            {(day.sleepComment||day.dayComment)&&<div className="hcard-comments">{day.sleepComment&&<div className="hcc">💬 {day.sleepComment}</div>}{day.dayComment&&<div className="hcc">⚡ {day.dayComment}</div>}</div>}
            <div className="hcard-hint">Appuyer pour modifier →</div>
          </div>
        );
      })}
    </div>
  );
}

function WeekView({weekStats,avg}){
  const entries=Object.entries(weekStats).sort(([a],[b])=>b.localeCompare(a));
  if(!entries.length) return <div className="empty">Aucune donnée hebdomadaire.</div>;
  return (
    <div className="list">
      {entries.map(([wk,s])=>{
        const an=avg(s.nights),ap=avg(s.naps),tot=an+ap;
        const wkDate=new Date(wk+"T12:00:00"),end=new Date(wk+"T12:00:00");end.setDate(end.getDate()+6);
        return (
          <div key={wk} className="scard">
            <div><div className="sc-period">Sem. du {wkDate.toLocaleDateString("fr-FR",{day:"numeric",month:"short"})}</div><div className="sc-sub">au {end.toLocaleDateString("fr-FR",{day:"numeric",month:"short"})} · {s.nights.length} nuits</div></div>
            <div className="sc-vals">
              <div className="scv night"><div className="scv-l">Nuit moy.</div><div className="scv-n">{formatDuration(an)}</div></div>
              {s.naps.length>0&&<div className="scv nap"><div className="scv-l">Sieste moy.</div><div className="scv-n">{formatDuration(ap)}</div></div>}
              <div className="scv total"><div className="scv-l">Total moy.</div><div className="scv-n">{formatDuration(tot)}</div></div>
            </div>
          </div>
        );
      })}
    </div>
  );
}

function MonthView({monthStats,avg}){
  const entries=Object.entries(monthStats).sort(([a],[b])=>b.localeCompare(a));
  if(!entries.length) return <div className="empty">Aucune donnée mensuelle.</div>;
  return (
    <div className="list">
      {entries.map(([mk,s])=>{
        const an=avg(s.nights),ap=avg(s.naps),tot=an+ap;
        const [yr,mo]=mk.split("-");
        const label=new Date(yr,mo-1).toLocaleDateString("fr-FR",{month:"long",year:"numeric"});
        return (
          <div key={mk} className="scard">
            <div><div className="sc-period" style={{textTransform:"capitalize"}}>{label}</div><div className="sc-sub">{s.nights.length} nuits enregistrées</div></div>
            <div className="sc-vals">
              <div className="scv night"><div className="scv-l">Nuit moy.</div><div className="scv-n">{formatDuration(an)}</div></div>
              {s.naps.length>0&&<div className="scv nap"><div className="scv-l">Sieste moy.</div><div className="scv-n">{formatDuration(ap)}</div></div>}
              <div className="scv total"><div className="scv-l">Total moy.</div><div className="scv-n">{formatDuration(tot)}</div></div>
            </div>
          </div>
        );
      })}
    </div>
  );
}

ReactDOM.render(<App/>, document.getElementById("root"));
</script>
</body>
</html>